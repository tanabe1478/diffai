{
  "name": "diffai",
  "version": "0.1.0",
  "description": "Review AI coding agent changes in a browser",
  "keywords": [
    "pi-package"
  ],
  "private": true,
  "repository": "github:tanabe1478/diffai",
  "type": "module",
  "bin": {
    "diffai": "dist/server/index.js"
  },
  "files": [
    "dist",
    "extensions",
    "skills",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "dev": "concurrently -k \"tsx watch server/index.ts --dev\" \"vite\"",
    "build": "vite build && tsup server/index.ts --format esm --platform node --out-dir dist/server",
    "prepare": "npm run build",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit",
    "test:e2e": "npm run build && playwright test"
  },
  "dependencies": {
    "@wooorm/starry-night": "^3.10.0",
    "diff": "^9.0.0",
    "express": "^5.1.0",
    "open": "^10.1.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^7.0.4"
  },
  "engines": {
    "node": ">=20"
  }
}
