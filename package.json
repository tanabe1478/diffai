{
  "name": "diffai",
  "version": "0.1.0",
  "description": "Review and approve Pi coding agent changes in a browser",
  "private": true,
  "repository": "github:tanabe1478/diffai",
  "type": "module",
  "bin": { "diffai": "dist/server/index.js" },
  "files": ["dist", "README.md"],
  "scripts": {
    "dev": "concurrently -k \"tsx watch server/index.ts --dev\" \"vite\"",
    "build": "vite build && tsup server/index.ts --format esm --platform node --out-dir dist/server --external @earendil-works/pi-coding-agent",
    "prepare": "npm run build",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "express": "^5.1.0",
    "open": "^10.1.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typebox": "^1.0.13",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.0",
    "tsx": "^4.20.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.4"
  },
  "engines": { "node": ">=20" }
}
